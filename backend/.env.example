# MongoDB Configuration
# For production (MongoDB Atlas), use MONGODB_URI
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/kirti_portfolio?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_uri_here

# For local development only (comment out in production)
MONGO_URL=mongodb://localhost:27017/
DB_NAME=kirti_portfolio

# Backend Configuration
CORS_ORIGINS=https://yourfrontend.vercel.app,https://kirtikilledar.com
JWT_SECRET=your_secure_random_jwt_secret_here
BACKEND_URL=https://your-backend.onrender.com

# LLM Integration (optional - only if using Emergent LLM features)
EMERGENT_LLM_KEY=your_emergent_llm_key_here

# Cloudinary Storage (required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
